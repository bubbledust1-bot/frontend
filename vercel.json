{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://backend-production-c2dcd.up.railway.app/api/$1"
    },
    {
      "source": "/ws/(.*)",
      "destination": "https://backend-production-c2dcd.up.railway.app/ws/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}